# Server-side secrets and provider config.
STATELESS_PROVIDER=nvidia
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_STATELESS_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
NVIDIA_NIM_API_KEY=nvapi-...
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# DigitalOcean serverless inference for comparative stateless measurement.
# DIGITALOCEAN_MODEL_ACCESS_KEY is preferred; DIGITALOCEAN_TOKEN is accepted as an alias.
DIGITALOCEAN_MODEL_ACCESS_KEY=sk-do-...
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_INFERENCE_BASE_URL=https://inference.do-ai.run
DIGITALOCEAN_INFERENCE_MODEL=nemotron-3-nano-omni
DEFAULT_PROVIDER_MODE=stateless-openrouter

# Engram / Clarit provider config.
ENGRAM_BASE_URL=http://localhost:30000
ENGRAM_API_KEY=
ENGRAM_ADMIN_API_KEY=
ENGRAM_MODEL=nvidia/nemotron-3-super-120b-a12b

# Server-side session and rate-limit controls.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEBUG=false
SESSION_DEBUG=false
SESSION_COOKIE_NAME=ngram_demo_session
# Leave blank to auto-use Secure on HTTPS and omit it on localhost HTTP.
SESSION_COOKIE_SECURE=
SESSION_TTL_SECONDS=3600
HEARTBEAT_TTL_SECONDS=90
MAX_ACTIVE_SESSIONS=24
MAX_GLOBAL_CONCURRENT_GENERATIONS=2
MAX_SESSION_CONCURRENT_GENERATIONS=1
MAX_REQUESTS_PER_SESSION_PER_MINUTE=6
MAX_REQUESTS_PER_IP_PER_MINUTE=18
MAX_INPUT_TOKENS_PER_REQUEST=12000

# Public browser config. No secrets here.
VITE_CHAT_API_URL=/api/chat
VITE_SESSION_API_URL=/api/session/heartbeat
VITE_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b
# Use simulated-engram until the real Engram service is reachable.
VITE_STATEFUL_PROVIDER_MODE=simulated-engram
VITE_SESSION_DEBUG=false
VITE_ENABLE_RECORDING_EXPORT=false
VITE_CONSENT_MODAL_TITLE=Ngram demonstration
VITE_CONSENT_MODAL_DESCRIPTION=This interactive simulation uses required cookies to keep a short-lived session, track active usage, and protect the live model from overload. By continuing, you acknowledge that the experience may connect to live inference providers and that request volume may be limited while the system is under test.
VITE_CONSENT_MODAL_ACCEPT=Start the simulation
VITE_CONSENT_MODAL_FOOTER=

# Optional local authoring endpoint for saving playback exports from the hidden recorder.
RECORDING_EXPORT_SERVER_ENABLED=false
RECORDING_EXPORT_DIR=.agent/recordings

# Optional local comparative recorder. Runs real Engram generation, then measures
# the frozen transcript against DigitalOcean serverless inference. Metrics are
# emitted into the v3 recording JSON, not configured here: Engram tokens,
# restore latency, snapshot saved/id/size, stateless cumulative tokens,
# stateless TTFT/prefill latency, and token reduction totals.
COMPARATIVE_RECORDING_ENABLED=false
COMPARATIVE_RECORDING_MODEL=nemotron-3-nano-omni
# Options: explicit-restore (actively times snapshot restore) or provider-metadata.
COMPARATIVE_RECORDING_RESTORE_MEASUREMENT=explicit-restore