# Server-side secrets and provider config.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_STATELESS_MODEL=nvidia/nemotron-3-super-120b-a12b
DEFAULT_PROVIDER_MODE=stateless-openrouter

# Engram / Clarit provider config.
ENGRAM_BASE_URL=http://localhost:30000
ENGRAM_API_KEY=
ENGRAM_ADMIN_API_KEY=
ENGRAM_MODEL=nvidia/nemotron-3-super-120b-a12b

# Server-side session and rate-limit controls.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEBUG=false
SESSION_DEBUG=false
SESSION_COOKIE_NAME=ngram_demo_session
# Leave blank to auto-use Secure on HTTPS and omit it on localhost HTTP.
SESSION_COOKIE_SECURE=
SESSION_TTL_SECONDS=3600
HEARTBEAT_TTL_SECONDS=90
MAX_ACTIVE_SESSIONS=24
MAX_GLOBAL_CONCURRENT_GENERATIONS=2
MAX_SESSION_CONCURRENT_GENERATIONS=1
MAX_REQUESTS_PER_SESSION_PER_MINUTE=6
MAX_REQUESTS_PER_IP_PER_MINUTE=18
MAX_INPUT_TOKENS_PER_REQUEST=12000

# Public browser config. No secrets here.
VITE_CHAT_API_URL=/api/chat
VITE_SESSION_API_URL=/api/session/heartbeat
VITE_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b
# Use simulated-engram until the real Engram service is reachable.
VITE_STATEFUL_PROVIDER_MODE=simulated-engram
VITE_SESSION_DEBUG=false
VITE_CONSENT_MODAL_TITLE=Ngram demonstration
VITE_CONSENT_MODAL_DESCRIPTION=This interactive demo uses required cookies to keep a short-lived session, track active usage, and protect the live model from overload. By continuing, you acknowledge that the demo may connect to live inference providers and that request volume may be limited while the system is under test.
VITE_CONSENT_MODAL_ACCEPT=Start the demo
VITE_CONSENT_MODAL_FOOTER=
