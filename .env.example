# Server-side secrets and provider config.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_STATELESS_MODEL=nvidia/nemotron-3-super-120b-a12b
DEFAULT_PROVIDER_MODE=stateless-openrouter

# Engram / Clarit provider config.
ENGRAM_BASE_URL=http://localhost:30000
ENGRAM_API_KEY=
ENGRAM_ADMIN_API_KEY=
ENGRAM_MODEL=nvidia/nemotron-3-super-120b-a12b

# Public browser config. No secrets here.
VITE_CHAT_API_URL=/api/chat
VITE_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b
# Use simulated-engram until the real Engram service is reachable.
VITE_STATEFUL_PROVIDER_MODE=simulated-engram
